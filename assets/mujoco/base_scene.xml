<!-- Base MuJoCo scene: lighting + ground plane. Field outline is injected at runtime. -->
<mujoco model="nr_ccp_base">
  <compiler angle="degree"/>
  <option timestep="0.01" gravity="0 0 -9.81"/>

  <visual>
    <headlight diffuse="0.85 0.85 0.85" ambient="0.25 0.25 0.25" specular="0.1 0.1 0.1"/>
    <rgba haze="0.55 0.65 0.75 1"/>
    <global azimuth="140" elevation="-28"/>
  </visual>

  <asset>
    <texture
      name="ground_tex"
      type="2d"
      builtin="checker"
      width="512"
      height="512"
      rgb1="0.32 0.48 0.28"
      rgb2="0.38 0.54 0.32"
    />
    <material name="ground_mat" texture="ground_tex" texrepeat="24 24" reflectance="0.08"/>
  </asset>

  <worldbody>
    <light pos="0 0 60" dir="0 0 -1" diffuse="0.95 0.95 0.95" castshadow="false"/>
    <light pos="40 40 30" dir="-1 -1 -1" diffuse="0.35 0.35 0.35" castshadow="false"/>
    <geom name="ground" type="plane" size="800 800 0.1" material="ground_mat"/>
    <include file="tractor.xml"/>
  </worldbody>
</mujoco>
